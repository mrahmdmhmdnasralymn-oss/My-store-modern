<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>متجر اليمن الحديث | Yemen Modern Store</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <style>
        :root {
            --primary: #2c3e50;
            --primary-dark: #1a252f;
            --accent: #f0b90b;
            --accent-hover: #d4a30a;
            --danger: #e74c3c;
            --success: #27ae60;
            --info: #3498db;
            --warning: #f39c12;
            --bg: #f5f6fa;
            --white: #ffffff;
            --text: #2d3436;
            --text-light: #636e72;
            --border: #e0e4e8;
            --shadow-sm: 0 2px 8px rgba(0,0,0,0.06);
            --shadow: 0 8px 25px rgba(0,0,0,0.08);
            --shadow-lg: 0 15px 35px rgba(0,0,0,0.12);
            --radius-sm: 10px;
            --radius: 16px;
            --radius-lg: 24px;
            --transition: 0.2s cubic-bezier(0.4, 0, 0.2, 1);
            --font: 'Cairo', sans-serif;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: var(--font);
            background: var(--bg);
            color: var(--text);
            line-height: 1.6;
            min-height: 100vh;
        }

        /* شريط علوي */
        .navbar {
            background: var(--white);
            box-shadow: var(--shadow-sm);
            padding: 0 20px;
            position: sticky;
            top: 0;
            z-index: 1000;
            border-bottom: 1px solid var(--border);
        }
        .navbar .container {
            max-width: 1400px;
            margin: auto;
            display: flex;
            align-items: center;
            justify-content: space-between;
            height: 70px;
        }
        .logo {
            font-size: 24px;
            font-weight: 900;
            color: var(--primary);
            display: flex;
            align-items: center;
            gap: 8px;
            text-decoration: none;
        }
        .logo i { color: var(--accent); font-size: 28px; }
        .nav-links { display: flex; gap: 20px; align-items: center; flex-wrap: wrap; }
        .nav-links a, .nav-links button {
            color: var(--text);
            text-decoration: none;
            font-weight: 600;
            background: none;
            border: none;
            cursor: pointer;
            font-size: 15px;
            display: flex;
            align-items: center;
            gap: 6px;
            transition: var(--transition);
            padding: 8px 12px;
            border-radius: 20px;
        }
        .nav-links a:hover, .nav-links button:hover { 
            color: var(--accent);
            background: #f8f9fa;
        }
        .cart-badge {
            background: var(--accent);
            color: var(--primary);
            border-radius: 50%;
            width: 22px;
            height: 22px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 12px;
            font-weight: 700;
            margin-right: -5px;
        }

        .main-container { max-width: 1400px; margin: 25px auto; padding: 0 20px; }

        .view { display: none; animation: fadeIn 0.4s ease; }
        .view.active { display: block; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

        /* لوحة التحكم */
        .admin-panel {
            background: var(--white);
            border-radius: var(--radius);
            padding: 30px;
            box-shadow: var(--shadow);
        }
        .admin-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
            flex-wrap: wrap;
            gap: 15px;
        }
        .admin-header h2 { font-size: 26px; color: var(--primary); display: flex; align-items: center; gap: 10px; }
        
        /* أزرار الإجراءات في الجدول */
        .btn-edit, .btn-update-qty, .btn-delete {
            padding: 8px 12px;
            border: none;
            border-radius: 6px;
            cursor: pointer;
            font-weight: 600;
            font-size: 13px;
            transition: var(--transition);
            display: inline-flex;
            align-items: center;
            gap: 4px;
            margin: 2px;
        }
        .btn-edit {
            background: #3498db;
            color: white;
        }
        .btn-edit:hover {
            background: #2980b9;
            transform: translateY(-1px);
        }
        .btn-update-qty {
            background: #f39c12;
            color: white;
        }
        .btn-update-qty:hover {
            background: #e67e22;
            transform: translateY(-1px);
        }
        .btn-delete {
            background: #e74c3c;
            color: white;
        }
        .btn-delete:hover {
            background: #c0392b;
            transform: translateY(-1px);
        }

        .logout-btn {
            background: var(--danger);
            color: white;
            border: none;
            padding: 10px 24px;
            border-radius: 30px;
            font-weight: 700;
            cursor: pointer;
            transition: var(--transition);
        }
        .logout-btn:hover { background: #c0392b; }

        .form-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-bottom: 25px;
        }
        .form-group { display: flex; flex-direction: column; gap: 8px; }
        .form-group label { font-weight: 600; color: var(--primary); font-size: 14px; }
        .form-group input, .form-group select {
            padding: 12px 16px;
            border: 2px solid var(--border);
            border-radius: var(--radius-sm);
            font-size: 15px;
            transition: var(--transition);
            background: #fafbfc;
        }
        .form-group input:focus, .form-group select:focus {
            border-color: var(--accent);
            background: white;
            outline: none;
            box-shadow: 0 0 0 3px rgba(240,185,11,0.15);
        }
        .image-upload-area {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
            align-items: center;
        }
        .btn-upload, .btn-camera {
            background: var(--primary-dark);
            color: white;
            border: none;
            padding: 12px 24px;
            border-radius: 30px;
            font-weight: 600;
            cursor: pointer;
            transition: var(--transition);
        }
        .btn-upload:hover, .btn-camera:hover { background: #0f1a24; }
        .camera-container { display: none; margin-top: 15px; text-align: center; }
        .camera-container.active { display: block; }
        #video { width: 100%; max-width: 360px; border-radius: var(--radius-sm); }
        .btn-capture {
            background: var(--success);
            color: white;
            border: none;
            padding: 10px 25px;
            border-radius: 30px;
            font-weight: 700;
            margin-top: 10px;
            cursor: pointer;
        }
        .image-preview img { max-width: 160px; border-radius: var(--radius-sm); margin-top: 10px; }

        .btn-submit {
            width: 100%;
            padding: 16px;
            background: var(--accent);
            color: var(--primary-dark);
            border: none;
            border-radius: 50px;
            font-size: 20px;
            font-weight: 900;
            cursor: pointer;
            transition: var(--transition);
            margin-top: 5px;
        }
        .btn-submit:hover { background: var(--accent-hover); transform: translateY(-2px); }

        .products-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 30px;
            background: white;
            border-radius: var(--radius-sm);
            overflow: hidden;
            box-shadow: var(--shadow-xs);
        }
        .products-table th {
            background: var(--primary);
            color: white;
            padding: 16px;
            font-weight: 600;
            font-size: 14px;
        }
        .products-table td {
            padding: 12px;
            text-align: center;
            border-bottom: 1px solid var(--border);
            vertical-align: middle;
        }
        .products-table img { width: 55px; height: 55px; object-fit: cover; border-radius: 8px; }
        .stock-badge {
            padding: 5px 14px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 700;
        }
        .stock-high { background: #d4edda; color: #155724; }
        .stock-medium { background: #fff3cd; color: #856404; }
        .stock-low { background: #f8d7da; color: #721c24; }
        .stock-out { background: #e2e3e5; color: #383d41; }

        /* المتجر */
        .store-layout { display: flex; gap: 25px; align-items: flex-start; }
        @media (max-width: 992px) { .store-layout { flex-direction: column; } }
        .products-main { flex: 1; }

        .search-section {
            background: var(--white);
            border-radius: var(--radius);
            padding: 20px;
            margin-bottom: 25px;
            box-shadow: var(--shadow-sm);
        }
        .search-box {
            display: flex;
            gap: 12px;
            margin-bottom: 15px;
        }
        .search-box input {
            flex: 1;
            padding: 14px 20px;
            border: 2px solid var(--border);
            border-radius: 30px;
            font-size: 16px;
            transition: var(--transition);
            background: #fafbfc;
        }
        .search-box input:focus {
            border-color: var(--accent);
            outline: none;
            box-shadow: 0 0 0 3px rgba(240,185,11,0.15);
        }
        .suggestions-dropdown {
            background: white;
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
            box-shadow: var(--shadow);
            max-height: 200px;
            overflow-y: auto;
            display: none;
            margin-top: -5px;
        }
        .suggestions-dropdown.active { display: block; }
        .suggestion-item {
            padding: 10px 20px;
            cursor: pointer;
            border-bottom: 1px solid #f0f0f0;
            transition: var(--transition);
        }
        .suggestion-item:hover { background: #f8f9fa; }
        .filter-pills {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
        }
        .filter-pill {
            padding: 8px 18px;
            border-radius: 20px;
            background: #f0f2f5;
            border: none;
            cursor: pointer;
            font-weight: 600;
            font-size: 13px;
            transition: var(--transition);
        }
        .filter-pill.active {
            background: var(--primary);
            color: white;
        }

        .products-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
            gap: 25px;
        }

        .product-card {
            background: var(--white);
            border-radius: var(--radius);
            overflow: hidden;
            box-shadow: var(--shadow-sm);
            transition: var(--transition);
            position: relative;
            border: 1px solid transparent;
        }
        .product-card:hover {
            transform: translateY(-6px);
            box-shadow: var(--shadow-lg);
            border-color: var(--border);
        }
        .product-card img {
            width: 100%;
            height: 200px;
            object-fit: cover;
            border-bottom: 1px solid #f0f0f0;
        }
        .product-card .badge {
            position: absolute;
            top: 12px;
            right: 12px;
            background: var(--accent);
            color: var(--primary-dark);
            padding: 4px 12px;
            border-radius: 20px;
            font-weight: 700;
            font-size: 12px;
        }
        .product-card .card-body { padding: 15px; }
        .product-card .category { color: var(--text-light); font-size: 13px; margin-bottom: 4px; }
        .product-card .name { font-weight: 700; font-size: 17px; margin-bottom: 6px; color: var(--primary); }
        .product-card .price { font-size: 24px; font-weight: 900; color: var(--accent); margin: 8px 0; }
        .product-card .stock-info { font-size: 13px; margin-bottom: 12px; }
        .qty-row { display: flex; align-items: center; gap: 10px; margin-bottom: 12px; }
        .qty-row input {
            width: 70px;
            padding: 8px;
            border: 2px solid #ddd;
            border-radius: 8px;
            text-align: center;
            font-weight: 700;
        }
        .btn-add-cart {
            width: 100%;
            padding: 12px;
            background: var(--primary);
            color: white;
            border: none;
            border-radius: 30px;
            font-weight: 700;
            font-size: 15px;
            cursor: pointer;
            transition: var(--transition);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
        }
        .btn-add-cart:hover:not(:disabled) {
            background: #1a252f;
            transform: scale(1.02);
        }
        .btn-add-cart:disabled {
            background: #bdc3c7;
            cursor: not-allowed;
        }

        /* السلة */
        .cart-panel {
            width: 360px;
            background: var(--white);
            border-radius: var(--radius);
            padding: 25px;
            box-shadow: var(--shadow);
            position: sticky;
            top: 85px;
            align-self: flex-start;
            border: 1px solid var(--border);
        }
        @media (max-width: 992px) {
            .cart-panel { width: 100%; position: static; margin-top: 20px; }
        }
        .cart-panel h3 { font-size: 22px; margin-bottom: 20px; color: var(--primary); display: flex; align-items: center; gap: 8px; }
        .cart-items-list { list-style: none; max-height: 320px; overflow-y: auto; padding-right: 4px; }
        .cart-item-row {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 12px;
            background: #f8fafc;
            border-radius: var(--radius-sm);
            margin-bottom: 8px;
        }
        .cart-item-info { flex: 1; }
        .cart-item-title { font-weight: 700; font-size: 14px; }
        .cart-item-price { color: var(--text-light); font-size: 12px; }
        .cart-qty-control { display: flex; align-items: center; gap: 5px; }
        .cart-qty-btn {
            background: var(--primary-dark);
            color: white;
            border: none;
            width: 26px;
            height: 26px;
            border-radius: 50%;
            font-weight: bold;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
        }
        .cart-total-box {
            font-size: 22px;
            font-weight: 900;
            margin: 20px 0;
            padding: 15px;
            background: #f1f3f5;
            border-radius: var(--radius-sm);
            text-align: center;
            color: var(--primary);
        }
        .btn-whatsapp {
            width: 100%;
            padding: 16px;
            background: #25D366;
            color: white;
            border: none;
            border-radius: 50px;
            font-size: 18px;
            font-weight: 900;
            cursor: pointer;
            transition: var(--transition);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }
        .btn-whatsapp:hover { background: #128C7E; transform: scale(1.02); }
        .empty-cart-note { text-align: center; color: #adb5bd; padding: 30px; font-size: 15px; }

        /* نافذة التعديل المنبثقة */
        .modal-overlay {
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.5);
            backdrop-filter: blur(4px);
            display: flex;
            justify-content: center;
            align-items: center;
            z-index: 10000;
            animation: fadeIn 0.3s;
        }
        .modal-box {
            background: white;
            border-radius: var(--radius);
            padding: 30px;
            box-shadow: var(--shadow-lg);
            width: 90%;
            max-width: 450px;
        }
        .modal-box h3 { margin-bottom: 20px; color: var(--primary); }
        .modal-box .form-group { margin-bottom: 15px; }
        .modal-box input {
            width: 100%;
            padding: 12px;
            border: 2px solid var(--border);
            border-radius: var(--radius-sm);
            font-size: 15px;
        }
        .modal-actions {
            display: flex;
            gap: 10px;
            margin-top: 20px;
        }
        .modal-actions button {
            flex: 1;
            padding: 12px;
            border: none;
            border-radius: 30px;
            font-weight: 700;
            cursor: pointer;
        }
        .btn-save { background: var(--success); color: white; }
        .btn-cancel { background: #ccc; }

        /* التوست */
        .toast-container {
            position: fixed;
            top: 20px;
            left: 50%;
            transform: translateX(-50%);
            z-index: 9999;
            display: flex;
            flex-direction: column;
            gap: 8px;
            pointer-events: none;
        }
        .toast {
            background: white;
            padding: 12px 24px;
            border-radius: 40px;
            box-shadow: var(--shadow-lg);
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 8px;
            animation: slideDown 0.4s, fadeOut 0.4s 2.8s forwards;
            pointer-events: auto;
        }
        .toast.success { border-right: 4px solid var(--success); }
        .toast.error { border-right: 4px solid var(--danger); }
        @keyframes slideDown { from{opacity:0;transform:translateY(-20px);} to{opacity:1;transform:translateY(0);} }
        @keyframes fadeOut { to{opacity:0;transform:translateY(-10px);} }

        /* كلمة المرور */
        .pw-overlay {
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.5);
            backdrop-filter: blur(6px);
            display: flex;
            justify-content: center;
            align-items: center;
            z-index: 10000;
        }
        .pw-box {
            background: white;
            padding: 35px;
            border-radius: var(--radius);
            box-shadow: var(--shadow-lg);
            text-align: center;
            width: 90%;
            max-width: 380px;
        }
        .pw-box input {
            width: 100%;
            padding: 12px;
            margin: 15px 0;
            border: 2px solid #ddd;
            border-radius: 8px;
            font-size: 16px;
            text-align: center;
        }
        .pw-box button {
            background: var(--primary);
            color: white;
            border: none;
            padding: 12px;
            border-radius: 30px;
            font-weight: 700;
            cursor: pointer;
            width: 100%;
        }
    </style>
</head>
<body>

<nav class="navbar">
    <div class="container">
        <a href="#" class="logo"><i class="fas fa-store-alt"></i> متجر اليمن الحديث</a>
        <div class="nav-links">
            <a href="tel:+967770189281"><i class="fas fa-phone"></i> 770189281</a>
            <a href="https://wa.me/967770189281" target="_blank"><i class="fab fa-whatsapp"></i> واتساب</a>
            <button onclick="switchToStore()"><i class="fas fa-shopping-bag"></i> المتجر <span class="cart-badge" id="cartCount">0</span></button>
            <button onclick="switchToAdmin()"><i class="fas fa-user-shield"></i> الإدارة</button>
        </div>
    </div>
</nav>

<div class="toast-container" id="toastContainer"></div>

<div class="main-container">
    <!-- لوحة التحكم -->
    <div id="adminView" class="view active">
        <div class="admin-panel">
            <div class="admin-header">
                <h2><i class="fas fa-boxes"></i> إدارة المنتجات والمخزون</h2>
                <button class="logout-btn" onclick="logout()"><i class="fas fa-sign-out-alt"></i> تسجيل خروج</button>
            </div>

            <form id="productForm">
                <div class="form-grid">
                    <div class="form-group">
                        <label>اسم المنتج *</label>
                        <input type="text" id="prodName" placeholder="مثال: هاتف ذكي" required>
                    </div>
                    <div class="form-group">
                        <label>السعر (ريال يمني) *</label>
                        <input type="number" id="prodPrice" step="0.01" min="0" placeholder="0.00" required>
                    </div>
                    <div class="form-group">
                        <label>القسم *</label>
                        <select id="prodCategory" required>
                            <option value="">اختر القسم</option>
                            <option>إلكترونيات</option><option>ملابس</option><option>أثاث</option>
                            <option>مواد غذائية</option><option>عطور</option><option>أخرى</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>الكمية في المخزون *</label>
                        <input type="number" id="prodQuantity" min="0" value="0" required>
                    </div>
                </div>

                <div class="form-group">
                    <label>صورة المنتج *</label>
                    <div class="image-upload-area">
                        <button type="button" class="btn-camera" onclick="openCamera()"><i class="fas fa-camera"></i> التقاط</button>
                        <span>أو</span>
                        <input type="file" id="imageUpload" accept="image/*" onchange="handleUpload(event)" hidden>
                        <button type="button" class="btn-upload" onclick="document.getElementById('imageUpload').click()"><i class="fas fa-upload"></i> رفع</button>
                    </div>
                    <div class="camera-container" id="cameraContainer">
                        <video id="video" autoplay playsinline></video>
                        <canvas id="canvas" hidden></canvas>
                        <button type="button" class="btn-capture" onclick="capturePhoto()">📸 التقاط</button>
                    </div>
                    <div class="image-preview" id="imagePreview"></div>
                </div>

                <button type="submit" class="btn-submit"><i class="fas fa-plus-circle"></i> إضافة المنتج</button>
            </form>

            <h3 style="margin:35px 0 15px; display: flex; align-items: center; gap: 10px;">
                <i class="fas fa-list"></i> المخزون الحالي
            </h3>
            <div style="overflow-x:auto;">
                <table class="products-table" id="productsTable">
                    <thead>
                        <tr>
                            <th>الصورة</th>
                            <th>الاسم</th>
                            <th>القسم</th>
                            <th>السعر</th>
                            <th>الكمية</th>
                            <th>الحالة</th>
                            <th>الإجراءات</th>
                        </tr>
                    </thead>
                    <tbody id="productsTbody"></tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- المتجر -->
    <div id="storeView" class="view">
        <div class="store-layout">
            <div class="products-main">
                <div class="search-section">
                    <div class="search-box">
                        <input type="text" id="searchInput" placeholder="🔍 ابحث عن منتج..." oninput="handleSearchInput()" autocomplete="off">
                    </div>
                    <div class="suggestions-dropdown" id="suggestionsDropdown"></div>
                    <div class="filter-pills" id="filterPills">
                        <button class="filter-pill active" onclick="setCategoryFilter('all', this)">الكل</button>
                    </div>
                </div>
                <div class="products-grid" id="storeGrid"></div>
            </div>
            <div class="cart-panel">
                <h3><i class="fas fa-shopping-cart"></i> سلة المشتريات</h3>
                <ul class="cart-items-list" id="cartItemsList"></ul>
                <div class="cart-total-box" id="cartTotalBox">الإجمالي: 0.00 ريال</div>
                <button class="btn-whatsapp" onclick="sendWhatsApp()">
                    <i class="fab fa-whatsapp"></i> إرسال الطلب واتساب
                </button>
            </div>
        </div>
    </div>
</div>

<!-- نافذة التعديل المنبثقة -->
<div id="editModal" class="modal-overlay" style="display:none;">
    <div class="modal-box">
        <h3><i class="fas fa-edit"></i> تعديل المنتج</h3>
        <div class="form-group">
            <label>اسم المنتج</label>
            <input type="text" id="editName">
        </div>
        <div class="form-group">
            <label>السعر (ريال)</label>
            <input type="number" id="editPrice" step="0.01" min="0">
        </div>
        <div class="form-group">
            <label>الكمية</label>
            <input type="number" id="editQuantity" min="0">
        </div>
        <div class="modal-actions">
            <button class="btn-save" onclick="saveEdit()">💾 حفظ التغييرات</button>
            <button class="btn-cancel" onclick="closeEditModal()">إلغاء</button>
        </div>
    </div>
</div>

<!-- نافذة كلمة المرور -->
<div id="pwOverlay" class="pw-overlay" style="display:none;">
    <div class="pw-box">
        <h3><i class="fas fa-shield-alt"></i> دخول المدير</h3>
        <p style="color:#666;">كلمة المرور: admin123</p>
        <input type="password" id="pwInput" placeholder="كلمة المرور">
        <button onclick="checkPassword()">دخول</button>
        <button onclick="closePwPrompt()" style="background:#ccc; margin-top:8px;">إلغاء</button>
    </div>
</div>

<script>
    (function() {
        const ADMIN_PASS = 'admin123';
        const STORE_PHONE = '967770189281';
        let currentImage = null;
        let cameraStream = null;
        let cart = [];
        let currentCategory = 'all';
        let editingProductId = null;

        function getProducts() { return JSON.parse(localStorage.getItem('storeProducts')) || []; }
        function saveProducts(p) { localStorage.setItem('storeProducts', JSON.stringify(p)); }
        function loadCart() { cart = JSON.parse(localStorage.getItem('storeCart')) || []; }
        function saveCart() { localStorage.setItem('storeCart', JSON.stringify(cart)); }

        function toast(msg, type='success') {
            const div = document.createElement('div');
            div.className = `toast ${type}`;
            div.innerHTML = msg;
            document.getElementById('toastContainer').appendChild(div);
            setTimeout(() => div.remove(), 3200);
        }

        function stockStatus(q) {
            if (q===0) return {text:'نفذ المخزون', cls:'stock-out'};
            if (q<=5) return {text:'منخفض', cls:'stock-low'};
            if (q<=20) return {text:'متوسط', cls:'stock-medium'};
            return {text:'متوفر', cls:'stock-high'};
        }

        // ========== لوحة التحكم ==========
        function renderAdminTable() {
            const prods = getProducts();
            const tbody = document.getElementById('productsTbody');
            if (!prods.length) {
                tbody.innerHTML = '<tr><td colspan="7" style="padding:30px;">📦 لا توجد منتجات في المخزون</td></tr>';
                return;
            }
            tbody.innerHTML = prods.map(p => {
                const st = stockStatus(p.quantity);
                return `
                <tr>
                    <td><img src="${p.image}" alt="${p.name}"></td>
                    <td><strong>${p.name}</strong></td>
                    <td>${p.category}</td>
                    <td>${p.price.toFixed(2)} ريال</td>
                    <td><strong>${p.quantity}</strong> قطعة</td>
                    <td><span class="stock-badge ${st.cls}">${st.text}</span></td>
                    <td>
                        <button class="btn-edit" onclick="openEditModal(${p.id})">
                            <i class="fas fa-edit"></i> تعديل
                        </button>
                        <button class="btn-update-qty" onclick="quickUpdateQty(${p.id})">
                            <i class="fas fa-cubes"></i> تحديث الكمية
                        </button>
                        <button class="btn-delete" onclick="deleteProduct(${p.id})">
                            <i class="fas fa-trash"></i> حذف
                        </button>
                    </td>
                </tr>`;
            }).join('');
        }

        // فتح نافذة التعديل
        window.openEditModal = function(id) {
            const prods = getProducts();
            const p = prods.find(x => x.id === id);
            if (!p) return;
            editingProductId = id;
            document.getElementById('editName').value = p.name;
            document.getElementById('editPrice').value = p.price;
            document.getElementById('editQuantity').value = p.quantity;
            document.getElementById('editModal').style.display = 'flex';
        };

        // حفظ التعديل
        window.saveEdit = function() {
            const prods = getProducts();
            const p = prods.find(x => x.id === editingProductId);
            if (!p) return;
            p.name = document.getElementById('editName').value.trim();
            p.price = parseFloat(document.getElementById('editPrice').value) || 0;
            p.quantity = parseInt(document.getElementById('editQuantity').value) || 0;
            saveProducts(prods);
            closeEditModal();
            renderAdminTable();
            renderStore();
            toast('✅ تم حفظ التعديلات بنجاح');
        };

        window.closeEditModal = function() {
            document.getElementById('editModal').style.display = 'none';
            editingProductId = null;
        };

        // تحديث سريع للكمية
        window.quickUpdateQty = function(id) {
            const prods = getProducts();
            const p = prods.find(x => x.id === id);
            if (!p) return;
            const newQty = prompt(`تحديث كمية "${p.name}"\nالكمية الحالية: ${p.quantity}\nأدخل الكمية الجديدة:`, p.quantity);
            if (newQty !== null && !isNaN(newQty) && parseInt(newQty) >= 0) {
                p.quantity = parseInt(newQty);
                saveProducts(prods);
                renderAdminTable();
                renderStore();
                toast(`✅ تم تحديث الكمية إلى ${newQty} قطعة`);
            }
        };

        // حذف منتج
        window.deleteProduct = function(id) {
            const prods = getProducts();
            const p = prods.find(x => x.id === id);
            if (!p) return;
            if (confirm(`هل أنت متأكد من حذف "${p.name}"؟\nلا يمكن التراجع عن هذا الإجراء.`)) {
                const filtered = prods.filter(x => x.id !== id);
                saveProducts(filtered);
                renderAdminTable();
                renderStore();
                toast('🗑️ تم حذف المنتج بنجاح', 'warning');
            }
        };

        // إضافة منتج
        document.getElementById('productForm').addEventListener('submit', function(e) {
            e.preventDefault();
            const name = document.getElementById('prodName').value.trim();
            const price = parseFloat(document.getElementById('prodPrice').value);
            const cat = document.getElementById('prodCategory').value;
            const qty = parseInt(document.getElementById('prodQuantity').value);
            if (!currentImage) { toast('⚠️ يرجى إضافة صورة للمنتج', 'error'); return; }
            const product = {
                id: Date.now(),
                name, price, category: cat, quantity: qty,
                image: currentImage,
                date: new Date().toISOString()
            };
            const prods = getProducts();
            prods.push(product);
            saveProducts(prods);
            this.reset();
            currentImage = null;
            document.getElementById('imagePreview').innerHTML = '';
            renderAdminTable();
            toast('🎉 تمت إضافة المنتج بنجاح');
        });

        // الكاميرا
        window.openCamera = async function() {
            const cont = document.getElementById('cameraContainer');
            if (cont.classList.contains('active')) { closeCamera(); return; }
            try {
                cameraStream = await navigator.mediaDevices.getUserMedia({video:{facingMode:'environment'}});
                document.getElementById('video').srcObject = cameraStream;
                cont.classList.add('active');
            } catch { toast('❌ تعذر الوصول للكاميرا', 'error'); }
        };
        function closeCamera() {
            if(cameraStream) { cameraStream.getTracks().forEach(t=>t.stop()); cameraStream=null; }
            document.getElementById('cameraContainer').classList.remove('active');
        }
        window.capturePhoto = function() {
            const video = document.getElementById('video');
            const canvas = document.getElementById('canvas');
            canvas.width = video.videoWidth;
            canvas.height = video.videoHeight;
            canvas.getContext('2d').drawImage(video,0,0);
            currentImage = canvas.toDataURL('image/jpeg',0.9);
            document.getElementById('imagePreview').innerHTML = `<img src="${currentImage}">`;
            closeCamera();
        };
        window.handleUpload = function(e) {
            const file = e.target.files[0];
            if(!file) return;
            const reader = new FileReader();
            reader.onload = ev => {
                currentImage = ev.target.result;
                document.getElementById('imagePreview').innerHTML = `<img src="${currentImage}">`;
            };
            reader.readAsDataURL(file);
        };

        // ========== المتجر ==========
        function getCategories() {
            return [...new Set(getProducts().map(p => p.category))];
        }

        function renderFilterPills() {
            const cats = getCategories();
            const container = document.getElementById('filterPills');
            container.innerHTML = '<button class="filter-pill active" onclick="setCategoryFilter(\'all\', this)">الكل</button>';
            cats.forEach(cat => {
                container.innerHTML += `<button class="filter-pill" onclick="setCategoryFilter('${cat}', this)">${cat}</button>`;
            });
        }

        window.setCategoryFilter = function(cat, btn) {
            currentCategory = cat;
            document.querySelectorAll('.filter-pill').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            renderStoreFiltered();
        };

        window.handleSearchInput = function() {
            const query = document.getElementById('searchInput').value.trim().toLowerCase();
            const dropdown = document.getElementById('suggestionsDropdown');
            if (query.length === 0) {
                dropdown.classList.remove('active');
                renderStoreFiltered();
                return;
            }
            const matches = getProducts().filter(p => p.name.toLowerCase().includes(query));
            if (matches.length > 0) {
                dropdown.innerHTML = matches.slice(0,5).map(p => 
                    `<div class="suggestion-item" onclick="selectSuggestion('${p.name}')">${p.name}</div>`
                ).join('');
                dropdown.classList.add('active');
            } else {
                dropdown.classList.remove('active');
            }
            renderStoreFiltered(query);
        };

        window.selectSuggestion = function(name) {
            document.getElementById('searchInput').value = name;
            document.getElementById('suggestionsDropdown').classList.remove('active');
            renderStoreFiltered(name.toLowerCase());
        };

        function renderStoreFiltered(query = null) {
            const searchTerm = query || document.getElementById('searchInput').value.trim().toLowerCase();
            const filtered = getProducts().filter(p => {
                const matchSearch = !searchTerm || p.name.toLowerCase().includes(searchTerm);
                const matchCat = currentCategory === 'all' || p.category === currentCategory;
                return matchSearch && matchCat;
            });
            const grid = document.getElementById('storeGrid');
            if (!filtered.length) {
                grid.innerHTML = '<p style="grid-column:1/-1;text-align:center;padding:40px;">😔 لا توجد منتجات متطابقة</p>';
                return;
            }
            grid.innerHTML = filtered.map(p => {
                const st = stockStatus(p.quantity);
                const disabled = p.quantity === 0;
                return `
                <div class="product-card">
                    <img src="${p.image}" alt="${p.name}">
                    <span class="badge">${p.category}</span>
                    <div class="card-body">
                        <div class="name">${p.name}</div>
                        <div class="price">${p.price.toFixed(2)} ريال</div>
                        <div class="stock-info">
                            <span class="stock-badge ${st.cls}">${st.text} (${p.quantity})</span>
                        </div>
                        <div class="qty-row">
                            <span>الكمية:</span>
                            <input type="number" id="qty-${p.id}" value="1" min="1" max="${p.quantity}" ${disabled?'disabled':''}>
                        </div>
                        <button class="btn-add-cart" onclick="addToCart(${p.id})" ${disabled?'disabled':''}>
                            ${disabled ? '🚫 نفذ المخزون' : '<i class="fas fa-cart-plus"></i> أضف إلى السلة'}
                        </button>
                    </div>
                </div>`;
            }).join('');
        }

        function renderStore() {
            renderFilterPills();
            renderStoreFiltered();
        }

        window.addToCart = function(id) {
            const product = getProducts().find(p=>p.id===id);
            if(!product || product.quantity===0) { toast('⚠️ غير متوفر', 'error'); return; }
            const qtyInput = document.getElementById(`qty-${id}`);
            const reqQty = parseInt(qtyInput?.value) || 1;
            if(reqQty<1) return;
            const exist = cart.find(i=>i.id===id);
            const currentInCart = exist ? exist.quantity : 0;
            if(currentInCart + reqQty > product.quantity) {
                toast(`⚠️ المتاح فقط ${product.quantity} قطعة`, 'error');
                return;
            }
            if(exist) exist.quantity += reqQty;
            else cart.push({id:product.id, name:product.name, price:product.price, quantity:reqQty});
            saveCart();
            renderCart();
            updateCartBadge();
            toast(`✅ أضيف ${reqQty} قطعة`);
            if(qtyInput) qtyInput.value = 1;
        };

        function renderCart() {
            const list = document.getElementById('cartItemsList');
            const totalBox = document.getElementById('cartTotalBox');
            if(!cart.length) {
                list.innerHTML = '<li class="empty-cart-note"><i class="fas fa-shopping-basket"></i> السلة فارغة</li>';
                totalBox.textContent = 'الإجمالي: 0.00 ريال';
                return;
            }
            list.innerHTML = cart.map(item => `
                <li class="cart-item-row">
                    <div class="cart-item-info">
                        <div class="cart-item-title">${item.name}</div>
                        <div class="cart-item-price">${item.price.toFixed(2)} ريال</div>
                    </div>
                    <div class="cart-qty-control">
                        <button class="cart-qty-btn" onclick="changeCartQty(${item.id}, -1)">−</button>
                        <span style="font-weight:bold; min-width:20px; text-align:center;">${item.quantity}</span>
                        <button class="cart-qty-btn" onclick="changeCartQty(${item.id}, 1)">+</button>
                    </div>
                    <button onclick="removeCartItem(${item.id})" style="background:none;border:none;color:var(--danger);cursor:pointer;font-size:16px;"><i class="fas fa-trash-alt"></i></button>
                </li>
            `).join('');
            const total = cart.reduce((s,i)=> s + i.price*i.quantity, 0);
            totalBox.textContent = `الإجمالي: ${total.toFixed(2)} ريال`;
        }

        window.changeCartQty = function(id, delta) {
            const item = cart.find(i=>i.id===id);
            if(!item) return;
            const newQty = item.quantity + delta;
            if(newQty<1) { removeCartItem(id); return; }
            const product = getProducts().find(p=>p.id===id);
            if(product && newQty > product.quantity) {
                toast(`⚠️ أقصى كمية: ${product.quantity}`, 'error');
                return;
            }
            item.quantity = newQty;
            saveCart();
            renderCart();
            updateCartBadge();
        };

        window.removeCartItem = function(id) {
            cart = cart.filter(i=>i.id!==id);
            saveCart();
            renderCart();
            updateCartBadge();
            toast('🗑️ حذف من السلة', 'warning');
        };

        function updateCartBadge() {
            document.getElementById('cartCount').textContent = cart.reduce((s,i)=> s + i.quantity, 0);
        }

        window.sendWhatsApp = function() {
            if(!cart.length) { toast('⚠️ السلة فارغة', 'error'); return; }
            let msg = '🛒 *طلب جديد من متجر اليمن الحديث*\n\n';
            cart.forEach((item, i) => {
                msg += `${i+1}. ${item.name}\n`;
                msg += `   الكمية: ${item.quantity} | السعر: ${item.price} ريال\n`;
                msg += `   المجموع: ${(item.price*item.quantity).toFixed(2)} ريال\n\n`;
            });
            const total = cart.reduce((s,i)=> s + i.price*i.quantity, 0);
            msg += `💰 الإجمالي: ${total.toFixed(2)} ريال\n`;
            msg += '📞 يرجى تأكيد الطلب وبيانات التوصيل';
            window.open(`https://wa.me/${STORE_PHONE}?text=${encodeURIComponent(msg)}`, '_blank');
        };

        // ========== الحماية ==========
        function isAuth() { return sessionStorage.getItem('adminAuth')==='true'; }
        window.checkPassword = function() {
            if(document.getElementById('pwInput').value === ADMIN_PASS) {
                sessionStorage.setItem('adminAuth', 'true');
                document.getElementById('pwOverlay').style.display='none';
                switchToAdmin();
                toast('✅ دخول ناجح');
            } else toast('❌ كلمة مرور خاطئة', 'error');
        };
        window.closePwPrompt = function() {
            document.getElementById('pwOverlay').style.display='none';
            if(!isAuth()) switchToStore();
        };
        window.logout = function() {
            sessionStorage.removeItem('adminAuth');
            toast('تم تسجيل الخروج', 'warning');
            switchToStore();
        };

        function switchToAdmin() {
            if(!isAuth()) {
                document.getElementById('pwOverlay').style.display='flex';
                document.getElementById('pwInput').value='';
                document.getElementById('pwInput').focus();
                return;
            }
            document.getElementById('adminView').classList.add('active');
            document.getElementById('storeView').classList.remove('active');
            renderAdminTable();
        }

        function switchToStore() {
            document.getElementById('adminView').classList.remove('active');
            document.getElementById('storeView').classList.add('active');
            renderStore();
            renderCart();
            updateCartBadge();
        }

        window.switchToAdmin = switchToAdmin;
        window.switchToStore = switchToStore;

        // بدء التشغيل
        loadCart();
        updateCartBadge();
        if(isAuth()) { switchToAdmin(); } else { switchToStore(); }
        if(isAuth()) renderAdminTable();
    })();
</script>
</body>
</html>
